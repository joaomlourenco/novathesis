%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/calibri.sty
%% NOVA thesis configuration file
%%
%% Customization of fonts to use Calibri fontset
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/calibri.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “calibri” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use XeLaTeX or LuaLaTeX}%
}


%%=======================================================================
%% FONT VERIFICATION
%%=======================================================================

\ntcheckfonts{Calibri}{Regular,Italic,Bold,BoldItalic}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\setmainfont{Calibri}[
  Path           = \DIRFONTSTYLES/Fonts/,
  Extension      = .ttf,
  Ligatures      = TeX,
  UprightFont    = *-Regular,
  ItalicFont     = *-Italic,
  BoldFont       = *-Bold,
  BoldItalicFont = *-BoldItalic,
]
