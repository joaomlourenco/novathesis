%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/futura.sty
%% NOVA thesis configuration file
%%
%% Customization of fonts to use Futura fontset
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/futura.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “futura” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use XeLaTeX or LuaLaTeX}%
}


%%=======================================================================
%% FONT VERIFICATION
%%=======================================================================

\ntcheckfonts{Futura}{Regular,Italic,Bold,BoldItalic}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\setmainfont{Futura}[
  Path           = \DIRFONTSTYLES/Fonts/,
  Extension      = .ttf,
  Ligatures      = TeX,
  UprightFont    = *-Regular,
  ItalicFont     = *-Italic,
  BoldFont       = *-Bold,
  BoldItalicFont = *-BoldItalic,
]
