%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/newsgott.sty
%% NOVA thesis configuration file
%%
%% Customization of font to use a News Gothic T font set
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/newsgott.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “newsgott” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use LuaLaTeX}%
}


%%=======================================================================
%% FONT VERIFICATION
%%=======================================================================

\ntcheckfonts{NewsGotT}{Regular,Bold}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\AtEndPreamble{%
  \RequirePackage[type1]{cabin}% used only by \mathsf
  \RequirePackage{amsthm}% load before newtxmath
  \RequirePackage[libertine,vvarbb]{newtxmath}% does not load minnewsgott because another Roman text package was specified

  \setmainfont{NewsGotT}[
    Ligatures = TeX,
    Path = \DIRFONTSTYLES/Fonts/,
    UprightFont = NewsGotT-Regular.ttf,
    BoldFont = NewsGotT-Bold.ttf,
    AutoFakeSlant = 0.15,
    BoldSlantedFont = NewsGotT-Bold.ttf,
    BoldItalicFont = NewsGotT-Bold.ttf,
    BoldSlantedFeatures = {FakeSlant = 0.15},
    BoldItalicFeatures = {FakeSlant = 0.15},
    Scale = 1.003764115,
  ]
}
