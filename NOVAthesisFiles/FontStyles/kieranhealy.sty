%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/kieranhealy.sty
%% NOVA thesis configuration file
%%
%% Customization of fonts to use Kieran Healy's fontset (MinionPro, MyriadPro, PragmataPro)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/kieranhealy.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “kieranhealy” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use XeLaTeX or LuaLaTeX}%
}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\setromanfont[Path=\DIRFONTSTYLES/Fonts/,
              BoldItalicFont=MinionPro-Bold-Italic.otf,
              BoldFont      =MinionPro-Bold.otf,
              ItalicFont    =MinionPro-Italic.otf,
              Mapping       ={tex-text},
              Numbers       ={OldStyle},
              Ligatures     ={Common},
              Scale         =1.10,
]{MinionPro}

\setsansfont[Path=\DIRFONTSTYLES/Fonts/,
             BoldItalicFont=MyriadPro-Bold-Italic.otf,
             BoldFont      =MyriadPro-Bold.otf,
             ItalicFont    =MyriadPro-Italic.otf,
             Mapping=tex-text,
             Ligatures={Common},
]{MyriadPro}

\setmonofont[Path=\DIRFONTSTYLES/Fonts/,
             Mapping=tex-text,
             Scale=0.90,
]{PragmataPro}
