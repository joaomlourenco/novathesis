%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/verdana.sty
%% NOVA thesis configuration file
%%
%% Customization of fonts to use Verdana fontset
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/verdana.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “verdana” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use XeLaTeX or LuaLaTeX}%
}


%%=======================================================================
%% FONT VERIFICATION
%%=======================================================================

\ntcheckfonts{VerdanaPro}{Regular,Italic,Bold,BoldItalic}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\setmainfont{VerdanaPro}[
  Path = \DIRFONTSTYLES/Fonts/,
  Extension = .ttf,
  Ligatures=TeX,
  UprightFont = *-Regular,
  ItalicFont = *-Italic,
  BoldFont = *-Bold,
  BoldItalicFont = *-BoldItalic,
]
