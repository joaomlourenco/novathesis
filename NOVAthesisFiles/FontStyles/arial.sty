%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FontStyles/arial.sty
%% NOVA thesis configuration file
%%
%% Customization of fonts to use Arial fontset
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE FontStyles/arial.sty}%


%%=======================================================================
%% ENGINE CHECK
%%=======================================================================

\ifxeorlua{}{%
  \ClassError{novathesis}{Font Style “arial” is not compatible with pdfLaTeX. Please use XeLaTeX or LuaLaTeX}{Please use XeLaTeX or LuaLaTeX}%
}


%%=======================================================================
%% FONT VERIFICATION
%%=======================================================================

\ntcheckfonts{Arial}{Regular,Italic,Bold,BoldItalic}


%%=======================================================================
%% FONT SELECTION
%%=======================================================================

\setmainfont{Arial}[
  Path = \DIRFONTSTYLES/Fonts/,
  Extension = .ttf,
  Ligatures=TeX,
  Mapping=tex-text,
  UprightFont=*-Regular,
  ItalicFont=*-Italic,
  BoldFont=*-Bold,
  BoldItalicFont=*-BoldItalic,
]
