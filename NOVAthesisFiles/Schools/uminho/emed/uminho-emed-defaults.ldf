\typeout{NT FILE uminho/emed/schl-defaults.ldf}%


%%=======================================================================
%% STRINGS (UNIVERSITY & SCHOOL)
%%=======================================================================

% Faculty / School
\SetSchool*(pt)={Escola de Medicina​}
\SetSchool*(en)={School of Medicine​}
\SetSchool*(fr)={\GetSchool(en)}
\SetSchool*(it)={\GetSchool(en)}

% Logos
\SetSchool*(logo,RGB)={uminho-em-insignia-color}
\SetSchool*(logo,GRAY)={uminho-em-insignia-mono}
