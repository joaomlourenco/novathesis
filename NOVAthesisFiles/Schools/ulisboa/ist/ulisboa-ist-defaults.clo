%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% ul/ist/defaults.clo
%% NOVA thesis configuration file
%%
%% Customization for IST-UL (strings and cover)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE ul/ist/defaults.clo}%


%%=======================================================================
%% METADATA & GLOBAL PROPERTIES
%%=======================================================================

\options{/novathesis,
% ULISBOA/IST
  ulisboa/ist/classification/.new value = {},
  ulisboa/ist/funding/.new value        = {},
}

\ifdocfinal{\ntsetup{print/frontpage=true}}{}


%%=======================================================================
%% STRINGS (UNIVERSITY & SCHOOL)
%%=======================================================================

% Faculty / School
\SetSchool*(pt)={Instituto Superior Técnico}
\SetSchool*(en)={Instituto Superior Técnico}
\SetSchool*(fr)={Instituto Superior Técnico}
\SetSchool*(it)={Instituto Superior Técnico}

\SetAdviserString*(a,1,m,en)={Supervisor}
\SetAdviserString*(a,1,f,en)={Supervisor}
\SetAdviserString*(a,2,m,en)={Supervisor}
\SetAdviserString*(a,2,f,en)={Supervisor}
\SetAdviserString*(c,1,m,en)={Co-supervisor}
\SetAdviserString*(c,1,f,en)={Co-supervisor}
\SetAdviserString*(c,2,m,en)={Co-supervisor}
\SetAdviserString*(c,2,f,en)={Co-supervisor}
\SetAdviserString*(ca,1,m,en)={Co-supervisor}
\SetAdviserString*(ca,1,f,en)={Co-supervisor}
\SetAdviserString*(ca,2,m,en)={Co-supervisor}
\SetAdviserString*(ca,2,f,en)={Co-supervisor}

\SetDegreeString*(bsc,m,en)={BSc}
\SetDegreeString*(bsc,f,en)={BSc}
\SetDegreeString*(msc,m,en)={MSc}
\SetDegreeString*(msc,f,en)={MSc}
\SetDegreeString*(mscplan,m,en)={MSc}
\SetDegreeString*(mscplan,f,en)={MSc}
\SetDegreeString*(phd,m,en)={PhD Degree}
\SetDegreeString*(phd,f,en)={PhD Degree}
\SetDegreeString*(phdplan,m,en)={PhD Degree}
\SetDegreeString*(phdplan,f,en)={PhD Degree}
\SetDegreeString*(phdprop,m,en)={PhD Degree}

