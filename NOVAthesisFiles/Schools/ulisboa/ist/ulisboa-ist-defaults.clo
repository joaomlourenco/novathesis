  \SetDissertationString(mscplan,en)={Thesis approved in public session to obtain the %
    \GetDegreeString(\option{/novathesis/doctype},\expanded{\GetDocAuthor(gender)},\@LANG@COVER)\ in\\%
    {\fontsize{10.75}{12}\selectfont\GetMajorField(\@LANG@COVER)}}
  \SetDissertationString(msc,en)={Thesis approved in public session to obtain the %
