  %       ItalicFont = *-Italic,
  %       BoldFont = *-Bold,
  %       BoldItalicFont = *-BoldItalic,
  %       Ligatures = {NoCommon, TeX}, % This kills the 'oe' ligature while keeping '--'
  %     ]
  % \fi
  \sffamily%
  \color{white}
}

\NTAddToHook{cover/2-1/pre}{%
  % \iftutex
  %     \setsansfont{Inter}[
  %       Scale = 0.95,
  %       Extension = .otf,
  %       UprightFont = *-Regular,
