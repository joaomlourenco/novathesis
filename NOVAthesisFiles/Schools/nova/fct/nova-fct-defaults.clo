\typeout{NT FILE schools/nova/fct/nova-fct-defaults.clo}%


%%=======================================================================
%% METADATA & GLOBAL PROPERTIES
%%=======================================================================

\options{/novathesis,
% NOVA/FCT
  nova/fct/company/logo/.new value = {},
  nova/fct/company/name/.new value = {},
}

\ntsetup{print/frontpage=true}
\openany


%%=======================================================================
%% COLORS
%%=======================================================================

\definecolor{fctlightgreen}{RGB}{67,140,74}%
\definecolor{fctdarkgreen}{RGB}{67,140,74}%
\definecolor{fctlightblue}{RGB}{67,120,188}%
\definecolor{fctdarkblue}{RGB}{46,108,195}%
\definecolor{fctlightred}{RGB}{95,5,44}%
\definecolor{fctdarkred}{RGB}{117,37,60}%
\definecolor{fctlightbrown}{RGB}{129,87,36}%
\definecolor{fctdarkbrown}{RGB}{142,112,51}%

\def\@fctblackheight{4.088cm}


%%=======================================================================
%% STRINGS (UNIVERSITY & SCHOOL)
%%=======================================================================

% Faculty / School
\SetSchool*(cat)={NOVA School of Science and Technology}
\SetSchool*(cz)={NOVA School of Science and Technology}
\SetSchool*(de)={NOVA School of Science and Technology}
\SetSchool*(dk)={NOVA School of Science and Technology}
\SetSchool*(en)={NOVA School of Science and Technology}
\SetSchool*(es)={NOVA School of Science and Technology}
\SetSchool*(fr)={NOVA School of Science and Technology}
\SetSchool*(gr)={NOVA School of Science and Technology}
\SetSchool*(it)={NOVA School of Science and Technology}
\SetSchool*(nl)={NOVA School of Science and Technology}
\SetSchool*(pl)={NOVA School of Science and Technology}
\SetSchool*(pt)={Faculdade de Ciências e Tecnologia}
\SetSchool*(sk)={NOVA School of Science and Technology}
\SetSchool*(uk)={NOVA School of Science and Technology}

% Logos
\SetSchool*(logo,pt)={nova-fct-logo-pt}
\SetSchool*(logo,en)={nova-fct-logo-en}
\IfMemVoidTF{School}{logo,\@LANG@COVER}
  {\SetSchool*(logo)={\GetSchool(logo,en)}}
  {\SetSchool*(logo)={\GetSchool(logo,\@LANG@COVER)}}

\SetSchool*(logo,neg,pt)={nova-fct-logo-negative-pt}
\SetSchool*(logo,neg,en)={nova-fct-logo-negative-en}
\IfMemVoidTF{School}{logo,neg,\@LANG@COVER}
  {\SetSchool*(logo,neg)={\GetSchool(logo,neg,en)}}
  {\SetSchool*(logo,neg)={\GetSchool(logo,neg,\@LANG@COVER)}}


%%=======================================================================
%% COMMITTEE
%%=======================================================================

\SetCommitteeOrder*()={c,r,a,ca,m}%


%%=======================================================================
%% FONTS
%%=======================================================================

% Loading of fonts must be delayed until class "novathesis" is loaded
\AtEndPreamble{%
  \RequirePackage{gillius2}%
}


%%=======================================================================
%% LAYOUT (MARGINS)
%%=======================================================================

% Set margins for "normal" pages
\SetMargin*(screen,top)={3.5cm}
\SetMargin*(screen,bottom)={2.5cm}
\SetMargin*(screen,left)={3.0cm}
\SetMargin*(screen,right)={3.0cm}
\SetMargin*(paper,top)={3.5cm}
\SetMargin*(paper,bottom)={2.5cm}
\SetMargin*(paper,left)={3.0cm}
\SetMargin*(paper,right)={3.0cm}

% Set margins for cover pages
\SetMargin*(cover,top)={8.6cm}
\SetMargin*(cover,bottom)={1.5cm}
\SetMargin*(cover,left)={3.55cm}
\SetMargin*(cover,right)={2.0cm}
\SetMargin*(cover,2-1,top)={6.6cm}


%%=======================================================================
%% SPINE
%%=======================================================================

\SetSpine*(logo,phd)={\GetUniversity(logo,neg)}
\SetSpine*(logo,msc)={\GetSchool(logo,neg)}

\SpineSetup[%
  \def\spnimg{nova-fct-spine-red}%
  \def\spnlogo{\GetSpine(logo,msc)}
  \ifmscdoc{%
    \def\spnimg{nova-fct-spine-blue}%
  }{}%
  \ifphddoc{%
    \def\spnimg{nova-fct-spine-green}%
    \def\spnlogo{\GetSpine(logo,phd)}%
  }{}%
]{%
  bg/image                    = {\spnimg},
  bg/image/angle              = {-90},
  box/logo/bg/image           = {\spnlogo},
  box/logo/bg/image/angle/phd = {-90},
  box/date/fg/color           = {white},
  box/title/fg/color          = {white},
  box/author/fg/color         = {white},
  % debug,
}


%%=======================================================================
%% COVER PAGE SETUP (BACKGROUNDS)
%%=======================================================================

\SetThesisCover*(1-1,textcolor)={white}

% Set cover color (background image)
\ifcsname @novafctcovercolor\endcsname\else
  \def\@novafctcovercolor{red}
  \ifdocclass{msc}{\def\@novafctcovercolor{blue}}{}
  \ifdocclass{phd}{\def\@novafctcovercolor{green}}{}
\fi

\SetThesisCover*(\@DOCTYPE,1-1,image)={nova-fct-cover-\@novafctcovercolor-front}
\SetThesisCover*(\@DOCTYPE,N-2,image)={nova-fct-cover-\@novafctcovercolor-back}
\SetThesisCover*(\@DOCTYPE,spine,image)={nova-fct-\@novafctcovercolor-red}


%%=======================================================================
%% UTILITIES & HOOKS
%%=======================================================================

\newif\if@nt@hasbreak

\newcommand{\printdwithvspace}[2][2pt]{%
  % ---- Phase 1: probe — execute #2 in a discard box; \\ just sets a flag ----
  \@nt@hasbreakfalse
  \setbox\z@\hbox{%
    \def\\{\global\@nt@hasbreaktrue}%
    #2%
  }%
  % ---- Phase 2: typeset for real ----
  \if@nt@hasbreak
    % \\ found: redefine to append [#1] to each line break, then typeset
    \begingroup
      \let\@nt@origcr\\%
      \def\\{\@nt@origcr[#1]}%
      #2%
    \endgroup
  \else
    % No \\ found: prepend \\[#1] before the content
    \\[#1]#2%
  \fi
}

\NTAddToHook{cover/1-1/pre}{%
  % \iftutex
  %     \setsansfont{Inter}[
  %       Scale = 0.95,
