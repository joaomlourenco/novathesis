\RequirePackage{memstore}         % Higher-level memory store helpers (aiming to replace memory2)
\RequirePackage{stocksize}        % Paper / stock size handling


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FONTS & ENCODINGS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage{microtype}  % Microtypography: character protrusion & font expansion

\iftutex
  \RequirePackage[no-math]{fontspec}  % OpenType font selection (XeLaTeX / LuaLaTeX)
  \defaultfontfeatures{Ligatures=TeX}
\else
  \RequirePackage[T1]{fontenc}  % 256-glyph output encoding (pdfLaTeX)
\fi

% Preferred sans-serif stack: Inter → Helvet → Gillius2 → LaTeX default
\IfFileExists{inter.sty}
  {\RequirePackage[scaled=MatchLowercase]{inter}
   \iftutex
     \setsansfont{Inter}[Scale=MatchLowercase, Ligatures={TeX,NoCommon}]
     \renewcommand{\sffamily}{\fontspec{Inter}[Ligatures={TeX,NoCommon}]}
   \fi}
  {\IfFileExists{helvet.sty}
    {\RequirePackage[scaled=0.95]{helvet}}
    {\IfFileExists{gillius2.sty}
      {\RequirePackage[scaled=0.95]{gillius2}}
      {\ClassWarning{novathesis}{Could not find a suitable Sans Serif font… using the default!}}}}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% LANGUAGE & LOCALIZATION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage[english]{babel}  % Multilingual support; active language switched later

% Provide fallback stubs for older babel versions that lack these commands
\AtBeginDocument{%
  \ifx\bbl@ensure@bcp\@undefined
    \newcommand{\bbl@ensure@bcp}[2]{#2}%
  \fi
  \ifx\bbl@ensure@english\@undefined
    \newcommand{\bbl@ensure@english}[1]{#1}%
  \fi
}

\RequirePackage{csquotes}  % Must be loaded before biblatex


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% GRAPHICS & TABLES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage{tikz}     % PGF/TikZ drawing engine (used by cover renderer)
\RequirePackage[nobeamer]{graphbox} % Loads graphicx + \includegraphics[align=…]
\RequirePackage{colortbl} % Coloured table cells (\columncolor, \rowcolor, …)
\RequirePackage{xurl}               % Loads 'url' with improved line-breaking

% ── Customize Graphcics package ───────────────────────────────────────
\expandafter\graphicspath\expandafter{\expandafter{\DIRFIGURES/}}
\DeclareGraphicsExtensions{.pdf,.png,.tif,.jpg}
\providecommand*\appendtographicspath[1]{\xappto\Ginput@path{#1}}
\providecommand*\prependtographicspath[1]{\xpreto\Ginput@path{#1}}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% BIBLIOGRAPHY & INDEXING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \ntbibsetup{key=value,...} — pass options to biblatex before it is loaded.
% Must be called before \begin{document}.
\NewDocumentCommand{\ntbibsetup}{m}{%
  \@ifpackageloaded{biblatex}
      {\ClassError{novathesis}{Please load biblatex options earlier.}{}}
      {\PassOptionsToPackage{#1}{biblatex}}%
}

\input{\DIRCONFIG/2_biblatex}

% biblatex and imakeidx are deferred until after school configs are loaded
% so that school-specific options set via \ntbibsetup take full effect.
% imakeidx must be loaded before hyperref.
\NTAddToHook{afterloading/schoolconfig}{%
  \RequirePackage{biblatex}   % Modern bibliography engine (biber backend)
  \RequirePackage{imakeidx}   % Multiple-index support; must load before hyperref
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% HYPERREF & INTERACTIVE ELEMENTS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\AtEndPreamble{%
  \PassOptionsToPackage{
    bookmarksnumbered=true,
    breaklinks=true,
    colorlinks=true,
    pdfdisplaydoctitle=true,
    unicode=true,
  }{hyperref}
  \RequirePackage{hyperref}           % PDF hyperlinks, metadata & bookmarks
  \RequirePackage{fix-hyperref}       % Patches hyperref immediately after loading
  \RequirePackage{bookmark}           % Extends hyperref bookmarks

  % ── glossaries-extra (must be loaded after hyperref) ──────────────
  \PassOptionsToPackage{
    translate=babel,
    acronym,           % add acronyms listing
    symbols,           % add symbols listing
    % sanitizesort=false, % allow \gls inside sort keys
    % xindy={language=\@LANG@MAIN@LONG},
    nolong,
    nosuper,
    nolist,
    notree,
    nostyles,
    automake,
  }{glossaries-extra}
  \RequirePackage{glossaries-extra}   % Glossaries, acronyms & symbols (extends glossaries)
  \RequirePackage{glossary-xltabular} % xltabular-based glossary layout style

  % xindy language support for Greek
  \ifoptioncontains{/novathesis/lang/extra}{gr}
    {\PassOptionsToPackage{xindy={language=\expanded{\@LANG@MAIN@LONG}}}
                          {glossaries-extra}}
    {}

  \setglossarystyle{xltabular}
  \setabbreviationstyle[acronym]{long-short}
  \GlsXtrEnablePreLocationTag{\emph{(\small p.~}}{\emph{(\small pp.~}}
  \patchcmd{\@gls@automake@immediate}{-I xindy}{-q -I xindy}{}{}
  \renewcommand{\GlsXtrFormatLocationList}[1]{\emph{\small#1)}}
  \renewcommand{\glsnamefont}[1]{\textbf{#1}}
  \newcommand*{\glsplainhyperlink}[2]{%
    \begingroup
      \hypersetup{hidelinks}%
      \hyperlink{#1}{#2}%
    \endgroup
  }%

  % Ensure \printglossary inserts a PDF bookmark at the correct level
  \let\printglossaryORIG\printglossary
  \def\printglossary{%
    \bookmarksetupnext{level=1}%
    \printglossaryORIG%
  }

  \iftoggle{/novathesis/glossaries/list/reverse}
           {}
           {\setupglossaries{nonumberlist}}
  \@loadglossaryfiles\makeglossaries
}


