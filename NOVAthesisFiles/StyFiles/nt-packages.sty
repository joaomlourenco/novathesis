%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% CORE PACKAGES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% pdflatex is limited to 16 \write registers; LuaTeX allows 65536.
% morewrites virtualises the pool so all packages get the streams they need.
% Must be loaded before any other package calls \newwrite.
\RequirePackage{iftex}
\ifluatex\else\RequirePackage{morewrites}\fi

\RequirePackage[table,svgnames]{xcolor} % Must be loaded first to avoid option clashes
\RequirePackage{iftex}       % \ifpdftex, \ifxetex, \ifluatex, \iftutex …
\RequirePackage{ifplatform}  % \ifwindows, \iflinux, \ifmacosx
\RequirePackage{xfor}        % Extended \foreach loop (\xfor, \xforeach)
\RequirePackage{etoolbox}    % Programmer's toolbox: hooks, patching, booleans
\RequirePackage{xstring}     % String manipulation (\StrBehind, \StrCut, …)
\RequirePackage{catchfile}   % Read a file's contents into a macro
\RequirePackage{varwidth}    % Variable-width minipage environment
\RequirePackage{calc}        % Arithmetic in length/counter expressions
\RequirePackage{hologo}      % Typeset TeX-family logos
% Wrap \hologo in \NoCaseChange so \MakeUppercase never uppercases logo names
% (LaTeX 2020+ case-changing engine uppercases even protected-command arguments).
\renewcommand*\hologo[1]{\NoCaseChange{\hologoRobust{#1}}}
% In PDF strings (bookmarks) render \hologo{X} as plain text "X".
\AtBeginDocument{%
  \pdfstringdefDisableCommands{%
    \def\hologo#1{#1}%
  }%
}

% Add StyFiles and Strings to \input search path so bare filenames work
\xappto\input@path{{\DIRSTYFILES/}{\DIRSTRINGS/}}

\RequirePackage{options-ext}      % Key-value option system
\RequirePackage{nt-version}       % \novathesisversion / \novathesisdate
\RequirePackage{nt-covers}  % Cover page rendering engine
\RequirePackage{memstore}         % Data storage API (\NewMemStore, \MemSet, \MemGet, …)
\RequirePackage{stocksize}        % Paper / stock size handling


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% FONTS & ENCODINGS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage{microtype}  % Microtypography: character protrusion & font expansion

\iftutex
  \RequirePackage[no-math]{fontspec}  % OpenType font selection (XeLaTeX / LuaLaTeX)
  \defaultfontfeatures{Ligatures=TeX}
\else
  \RequirePackage[T1]{fontenc}  % 256-glyph output encoding (pdfLaTeX)
\fi

% Preferred sans-serif stack: Inter → Helvet → Gillius2 → LaTeX default
\IfFileExists{inter.sty}
  {\RequirePackage[scaled=MatchLowercase]{inter}
   \iftutex
     \setsansfont{Inter}[Scale=MatchLowercase, Ligatures={TeX,NoCommon}]
     \renewcommand{\sffamily}{\fontspec{Inter}[Ligatures={TeX,NoCommon}]}
   \fi}
  {\IfFileExists{helvet.sty}
    {\RequirePackage[scaled=0.95]{helvet}}
    {\IfFileExists{gillius2.sty}
      {\RequirePackage[scaled=0.95]{gillius2}}
      {\ClassWarning{novathesis}{Could not find a suitable Sans Serif font… using the default!}}}}


