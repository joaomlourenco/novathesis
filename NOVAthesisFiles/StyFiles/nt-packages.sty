%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% WRITE-REGISTER GUARD (must come before any other \newwrite)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% pdflatex is limited to 16 \write registers; LuaTeX allows 65536.
% morewrites virtualises the pool so all packages get the streams they need.
\RequirePackage{iftex}
\ifluatex\else\RequirePackage{morewrites}\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% KERNEL & CORE UTILITIES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Save \Roman / \@Roman immediately — pdflatex + greek (LGR encoding)
% clobbers them, and we need the originals for the \annex command.
\let\oldRoman=\Roman
\let\old@Roman=\@Roman

% ── Hook API ──────────────────────────────────────────────────────────
% Thin wrappers over the LaTeX kernel hook engine (LaTeX 2020-10-01+).
% Hook names are namespaced under 'novathesis/' to avoid conflicts with
% kernel or package hooks.  \ActivateGenericHook (LaTeX 2024+) makes
% \UseHook a silent no-op when no code has been added to the hook.
\newcommand*{\NTAddToHook}[2]{\AddToHook{novathesis/#1}{#2}}
\newcommand*{\NTDeclareHook}[1]{\ActivateGenericHook{novathesis/#1}}
\newcommand*{\NTRunHook}[1]{\ActivateGenericHook{novathesis/#1}\UseHook{novathesis/#1}}

