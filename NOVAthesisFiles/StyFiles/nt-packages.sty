%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% BIBLIOGRAPHY & INDEXING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \ntbibsetup{key=value,...} — pass options to biblatex before it is loaded.
% Must be called before \begin{document}.
\NewDocumentCommand{\ntbibsetup}{m}{%
  \@ifpackageloaded{biblatex}
      {\ClassError{novathesis}{Please load biblatex options earlier.}{}}
      {\PassOptionsToPackage{#1}{biblatex}}%
}

\input{\DIRCONFIG/2_biblatex}

% biblatex and imakeidx are deferred until after school configs are loaded
% so that school-specific options set via \ntbibsetup take full effect.
% imakeidx must be loaded before hyperref.
\NTAddToHook{afterloading/schoolconfig}{%
  \RequirePackage{biblatex}   % Modern bibliography engine (biber backend)
  \RequirePackage{imakeidx}   % Multiple-index support; must load before hyperref
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% HYPERREF & INTERACTIVE ELEMENTS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\AtEndPreamble{%
  % ── PDF/A-2b archival output (single-pass) ────────────────────────
  % When docstatus=final and pdfa=true (the default), load pdfx[a-2b]
  % BEFORE hyperref so pdfx controls the PDF version and XMP metadata.
  %
  % LuaLaTeX fix: pdfx.sty line 72 reads \pdfminorversion BEFORE loading
  % luatex85 (line 323), which maps \pdfminorversion → \pdfvariable minorversion
  % (= 7).  Pre-loading luatex85 here ensures \pdfminorversion = 7 when pdfx
  % reads it, so \pdfx@minorversion = 7 = \pdfminorversion at the version check
  % (line 341) → no "Cannot change the \pdfminorversion" error.
  % ── hyperref options (must be registered before anyone loads hyperref) ──
  % This block runs before the \ifdocfinal/pdfx block so that when pdfx
  % loads hyperref itself (in PDF/A-2b mode) these options are already
  % registered via \PassOptionsToPackage and are merged in at load time.
  \PassOptionsToPackage{
    bookmarksnumbered=true,
    bookmarksdepth=3,
    breaklinks=true,
    colorlinks=true,
    hypertexnames=true,     % prevents duplicate PDF destinations from memoir's double caption rendering
    pdfdisplaydoctitle=true,
    unicode=true,
  }{hyperref}
  \ifdocfinal{%
    \iftoggle{/novathesis/pdfa}{%
      % Write XMP metadata file for pdfx (cover data available from 3_cover.tex)
      \newwrite\@nt@xmp@out
      \immediate\openout\@nt@xmp@out=\jobname.xmpdata
      \immediate\write\@nt@xmp@out{\string\Title{\GetDocTitle(\@LANG@MAIN,main,plain)}}%
      \immediate\write\@nt@xmp@out{\string\Author{\GetDocAuthor(name)}}%
      \immediate\write\@nt@xmp@out{\string\Language{\@LANG@MAIN}}%
      \immediate\closeout\@nt@xmp@out
      % Pre-load luatex85 before pdfx so the pdfminorversion check is correct
      \@ifpackageloaded{luatex85}{}{\RequirePackage{luatex85}}%
      \RequirePackage[a-2b]{pdfx}%    % sets PDF/A-2b and embeds XMP metadata
    }{}%
  }{}%
  % ── hyperref ──────────────────────────────────────────────────────
  \RequirePackage{hyperref}           % PDF hyperlinks, metadata & bookmarks
  \RequirePackage{fix-hyperref}       % Patches hyperref immediately after loading
  \RequirePackage{bookmark}           % Extends hyperref bookmarks

  % ── glossaries-extra (must be loaded after hyperref) ──────────────
  \PassOptionsToPackage{
    translate=babel,
    acronym,           % add acronyms listing
    symbols,           % add symbols listing
    % sanitizesort=false, % allow \gls inside sort keys
    % xindy={language=\@LANG@MAIN@LONG},
    nolong,
    nosuper,
    nolist,
    notree,
    nostyles,
    automake,
  }{glossaries-extra}
  \RequirePackage{glossaries-extra}   % Glossaries, acronyms & symbols (extends glossaries)
  \RequirePackage{glossary-xltabular} % xltabular-based glossary layout style

  % xindy language support for Greek
  \ifoptioncontains{/novathesis/lang/extra}{gr}
    {\PassOptionsToPackage{xindy={language=\expanded{\@LANG@MAIN@LONG}}}
                          {glossaries-extra}}
    {}

  \setglossarystyle{xltabular}
  \setabbreviationstyle[acronym]{long-short}
  \GlsXtrEnablePreLocationTag{\emph{(\small p.~}}{\emph{(\small pp.~}}
  \patchcmd{\@gls@automake@immediate}{-I xindy}{-q -I xindy}{}{}
  \renewcommand{\GlsXtrFormatLocationList}[1]{\emph{\small#1)}}
  \renewcommand{\glsnamefont}[1]{\textbf{#1}}
  \newcommand*{\glsplainhyperlink}[2]{%
    \begingroup
      \hypersetup{hidelinks}%
      \hyperlink{#1}{#2}%
    \endgroup
  }%

  % Ensure \printglossary inserts a PDF bookmark at the correct level
  \let\printglossaryORIG\printglossary
  \def\printglossary{%
    \bookmarksetupnext{level=1}%
    \printglossaryORIG%
  }

  \iftoggle{/novathesis/glossaries/list/reverse}
           {}
           {\setupglossaries{nonumberlist}}
  \AtBeginDocument{\@loadglossaryfiles\makeglossaries}
}


