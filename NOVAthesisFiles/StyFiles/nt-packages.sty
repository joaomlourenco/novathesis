%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% KERNEL & CORE UTILITIES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Save \Roman / \@Roman immediately — pdflatex + greek (LGR encoding)
% clobbers them, and we need the originals for the \annex command.
\let\oldRoman=\Roman
\let\old@Roman=\@Roman

% ── Hook API ──────────────────────────────────────────────────────────
% Thin wrappers over the LaTeX kernel hook engine (LaTeX 2020-10-01+).
% Hook names are namespaced under 'novathesis/' to avoid conflicts with
% kernel or package hooks.  \ProvideHook ensures firing an empty hook
% is a silent no-op (matching \UseHook's undeclared-hook behaviour).
\newcommand*{\NTAddToHook}[2]{\AddToHook{novathesis/#1}{#2}}
\newcommand*{\NTRunHook}[1]{\ProvideHook{novathesis/#1}\UseHook{novathesis/#1}}

% ── Directory macros ──────────────────────────────────────────────────
\def\DIRCONFIG{0-Config}
\def\DIRFRONTMATTER{1-FrontMatter}
\def\DIRMAINMATTER{2-MainMatter}
\def\DIRBACKMATTER{3-BackMatter}
\def\DIRBIBLIOGRAPHY{4-Bibliography}
\def\DIRFIGURES{5-Figures}
\def\DIRNTFILES{./NOVAthesisFiles}
\def\DIRSTYFILES{\DIRNTFILES/StyFiles}
\def\DIRFONTSTYLES{\DIRNTFILES/FontStyles}
\def\DIRSCHOOLS{\DIRNTFILES/Schools}
\def\DIRSTRINGS{\DIRNTFILES/Strings}
\def\DIRCHAPSTYLES{\DIRNTFILES/ChapStyles}
\def\DIRIMAGES{\DIRNTFILES/Images}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% MEMOIR BASE CLASS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand*{\ntmemoirsetup}[1]{\PassOptionsToClass{#1}{memoir}}
\input{\DIRCONFIG/0_memoir}
\LoadClass{memoir}

\OnehalfSpacing


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% CORE PACKAGES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage[table,svgnames]{xcolor} % Must be loaded first to avoid option clashes
\RequirePackage{iftex}       % \ifpdftex, \ifxetex, \ifluatex, \iftutex …
\RequirePackage{ifplatform}  % \ifwindows, \iflinux, \ifmacosx
\RequirePackage{xfor}        % Extended \foreach loop (\xfor, \xforeach)
\RequirePackage{etoolbox}    % Programmer's toolbox: hooks, patching, booleans
\RequirePackage{xstring}     % String manipulation (\StrBehind, \StrCut, …)
\RequirePackage{catchfile}   % Read a file's contents into a macro
\RequirePackage{varwidth}    % Variable-width minipage environment
\RequirePackage{calc}        % Arithmetic in length/counter expressions

% Add StyFiles and Strings to \input search path so bare filenames work
\xappto\input@path{{\DIRSTYFILES/}{\DIRSTRINGS/}}

\RequirePackage{options-ext}      % Key-value option system
\RequirePackage{nt-version}       % \novathesisversion / \novathesisdate
\RequirePackage{nt-covers-expl3}  % Cover page rendering engine
