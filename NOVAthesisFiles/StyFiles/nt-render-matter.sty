\newcommand{\@nt@printifmaindoc@i}[1]{%
  % \typeout{NT Attempt to load #1}%
  \ifmaindoc{% THEN it is a main document
    \NTRunHook{#1/pre}%
    \iffileadded{#1}{%
      \ChapterNoTitle{\GetBkmString(#1,\@LANG@COPYRIGHT)}
      \PrintAddedFile{#1}%
