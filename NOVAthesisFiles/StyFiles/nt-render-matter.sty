        \textit{#3}\\
        \PrintDateISO{#4}
      \end{center}
    \end{minipage}
  }



%% Default list-of bookmark level (1 = direct child of Front/Back Matter group).
%% \ntprintalllistof overrides this to 2 when a "List of..." group header is present.
\def\@nt@lol@bkm@level{1}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Deal with optional lists in the frontmatter: listoftables, litoffigures, etc.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand*{\ntprintalllistof}{%
    \NTRunHook{listof/pre}%
    \if@backmatter
      \def\@matter{backmatter}
    \else
      \def\@matter{frontmatter}
      \iftoggle{/novathesis/tocintoc}
            {\begingroup
               % \tableofcontents (non-starred) creates a \chapter* bookmark that
               % would be shifted by any active \shiftbookmarks.  Temporarily reset
               % toclevel@chapter to 0 so Contents always appears at the root level.
               \expandafter\def\csname toclevel@chapter\endcsname{0}%
               \tableofcontents
             \endgroup}%
            {\bookmark[level=0, dest=\HyperLocalCurrentHref]{\contentsname}
             \tableofcontents*}%
    \fi
    \ifoptiondefined{/@nt/listof/\@matter}{
      \edef\@nt@listof@bkmtitle{\GetBkmString(listof,\@LANG@MAIN)}%
      \clearforchapter%
      \phantomsection%
      \bookmark[level=0, dest=\HyperLocalCurrentHref]{\@nt@listof@bkmtitle}%
      \optionlistdo{/@nt/listof/\@matter}{##1}%
    }{}%
    \NTRunHook{listof/post}%
}


