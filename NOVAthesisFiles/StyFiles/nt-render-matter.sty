%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% LISTINGS + MINTED UNIFICATION
%% Goal: one counter, one list, regardless of which package(s) are loaded.
%%
%% IMPORTANT: listings.sty defers \newcounter{lstlisting} to \AtBeginDocument,
%% so counter aliasing must run AFTER that hook completes.
%% \AddToHook{begindocument/end} fires after ALL \AtBeginDocument hooks.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\AddToHook{begindocument/end}{%
  \makeatletter
    % 1. Helper for TOC/Bookmark injection
    \newcommand{\update@lol}[1]{%
      % \cleardoublepage
      % \phantomsection
      % \addcontentsline{toc}{chapter}{\listoflistingscaption}%
      #1%
    }

    % 2. Helper to set numbering to Chapter.Sequence
    % This defines \thelisting as \thechapter.\arabic{listing} 
    % and ensures the counter resets when \chapter is called.
    \newcommand{\setup@listing@numbering}[1]{%
      \@addtoreset{#1}{chapter}%
      \expandafter\renewcommand\csname the#1\endcsname{\thechapter.\arabic{#1}}%
    }

    \@ifpackageloaded{listings}{%
      \@ifpackageloaded{minted}{%
        % --- CASE: BOTH LOADED ---
        \let\old@listoflistings\listoflistings
        \renewcommand{\listoflistings}{\update@lol{\old@listoflistings}}
        \let\lstlistoflistings\listoflistings
      
        % Setup numbering for 'listing' (minted's counter)
        \setup@listing@numbering{listing}
        % Unify 'listings' to follow 'minted'
        \let\c@lstlisting\c@listing
        \let\thelstlisting\thelisting
      }{%
        % --- CASE: ONLY LISTINGS LOADED ---
        \ifx\listoflistingscaption\@undefined
          \let\listoflistingscaption\lstlistlistingname
        \fi
        \let\old@lstlistoflistings\lstlistoflistings
        \renewcommand{\lstlistoflistings}{\update@lol{\old@lstlistoflistings}}
        \let\listoflistings\lstlistoflistings
      
        % Setup numbering for 'lstlisting'
        \setup@listing@numbering{lstlisting}
      }%
    }{%
      \@ifpackageloaded{minted}{%
        % --- CASE: ONLY MINTED LOADED ---
        \let\old@listoflistings\listoflistings
        \renewcommand{\listoflistings}{\update@lol{\old@listoflistings}}
      
        % Setup numbering for 'listing'
        \setup@listing@numbering{listing}
      }{%
        % NEITHER LOADED
      }%
    }%
  \makeatother
}

\NTAddToHook{mainmatter/post}{%
  \ifoptionequal{/novathesis/numbering/floats}{sequential}{%
    \counterwithout{figure}{chapter}%
    \counterwithout{table}{chapter}%
    \counterwithout{footnote}{chapter}%
    \counterwithout{equation}{chapter}%
    \@ifundefined{c@algorithm}{}{\counterwithout{algorithm}{chapter}}%
    %% Counter unification (listings+minted) is handled at \AtBeginDocument above.
    %% Here we only need the \counterwithout calls.
    \@ifpackageloaded{minted}{%
      \@ifundefined{c@listing}{}{\counterwithout{listing}{chapter}}%
    }{%
      \@ifpackageloaded{listings}{%
        \@ifundefined{c@lstlisting}{}{\counterwithout{lstlisting}{chapter}}%
      }{}%
    }%
  }{}%
}


