% Keep legacy \GetPersonsAsList as a wrapper to the new expl3 function
\NewDocumentCommand { \GetPersonsAsList } { m m o }
 {
  \IfNoValueTF { #3 }
   {
    \nt_persons_format_as_list:nn { #1 } { #2 }
   }
   {
    \nt_persons_get_list:nnn { #1 } { #2 } { #3 }
   }
 }

% Preserve legacy \FormatNamesAsList for backward compatibility
\cs_generate_variant:Nn \seq_set_from_clist:Nn { Ne }
\cs_generate_variant:Nn \seq_use:Nnnn { Neee }

\NewDocumentCommand { \FormatNamesAsList } { m                  % list of names
                                              O{ }              % prefix
                                              O{ \GetCommaString(\@LANG@MAIN) } % middle-sep
                                              O{ ~ \GetAndString(\@LANG@MAIN) } % pair-sep
                                              O{ \GetCommaString(\@LANG@MAIN)\GetAndString(\@LANG@MAIN) } } % last-sep
 {
  \seq_set_from_clist:Ne \l_tmpa_seq { #1 }
  \seq_clear:N \l_tmpb_seq
  \seq_map_inline:Nn \l_tmpa_seq
   {
    \seq_put_right:Nn \l_tmpb_seq { #2 ~ ##1 }
   }
  \seq_use:Neee \l_tmpb_seq { #2 } { #3 } { #4 }
 }

% Message definitions for error reporting
\msg_new:nnn { novathesis } { invalid-value }
 { Invalid ~ value: ~ #1 }

\msg_new:nnn { novathesis } { invalid-alignment }
 { Invalid ~ alignment ~ character ~ '#1' ~ (must ~ be ~ l, ~ c, ~ or ~ r) }

\msg_new:nnn { novathesis } { invalid-colcount }
 { Invalid ~ column ~ count: ~ #1 }

