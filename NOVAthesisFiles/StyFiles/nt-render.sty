    \fi
    \ifskipabstract
      \ClassWarning{novathesis}{Skipping abstract '#1' under pdfLaTeX (CJK Unicode). Use 'make xe' or 'make lua' to include Chinese abstracts.}%
    \else
      % \typeout{NT PRINT ABSTRACT 2=[#1]}\NTPRINTABSTRACT@II
