% --------------------------------------------------------
% Title
\def\nttitle(#1,#2)#3{%
  % #1 = type (main, sub, spine) title
  % #2 = lang
  % #3 = value
  % \typeout{NT TITLE [#1] [#2] [#3]}%
  \doctitle(#2,#1):={#3}%
  \NewlineToSpace{#3}[\tmp]%
  \doctitle(#2,#1,plain):={\tmp}% 
  \IfStrEq{#1}{main}{\doctitle(#2,spine):={\tmp}}{}%
}


