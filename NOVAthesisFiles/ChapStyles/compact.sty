%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% NOVAthesisFiles/ChapStyles/compact.sty
%% NOVA thesis configuration file
%%
%% Customization for the Compact chapter style
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\typeout{NT FILE NOVAthesisFiles/ChapStyles/compact.sty}%


%%=======================================================================
%% CHAPTER STYLE
%%=======================================================================

\chapterstyle{section}

\setlength{\beforechapskip}{3.5ex \@plus 1ex \@minus .2ex}
\renewcommand*{\chapterheadstart}{\vspace{\beforechapskip}}
\setlength{\afterchapskip}{2.3ex \@plus .2ex}

\renewcommand*{\chapnumfont}{\normalfont\HUGE\sffamily}
\renewcommand*{\chaptitlefont}{\normalfont\huge\sffamily}


%%=======================================================================
%% SECTION STYLES
%%=======================================================================

\gappto{\secheadstyle}{\sffamily}
\gappto{\subsecheadstyle}{\sffamily}
\gappto{\subsubsecheadstyle}{\sffamily}
