  \StartBabelCommands*{french}{date}
    \SetStringLoop{month#1name}{
      Janvier,Février,Mars,Avril,Mai,Juin,%
      Juillet,Août,Septembre,Octobre,Novembre,%
      Décembre}
  \EndBabelCommands
}
